# StoryVerse Web — environment configuration
# Copy to `.env.local` and fill in as needed. Every variable is optional:
# with none set, the app runs in degraded mode (seed catalog + deterministic
# agents) and boots without any external service.

# --- Neo4j knowledge graph (all three required together to enable graph mode) ---
# Without these, the catalog serves the seed + generated-file fallback and the
# navigator returns heuristic suggestions instead of graph neighbours.
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# --- OpenAI (optional) ---
# When set, enables gpt-4o-mini for storyteller narration and navigator
# re-ranking. Without it, agents use deterministic templates.
OPENAI_API_KEY=

# --- Ollama catalog generator (optional) ---
# OpenAI-compatible endpoint used by POST /api/catalog/generate.
# Point this at your own Ollama host; the in-code default is an internal lab
# address and will not resolve elsewhere.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3:32b

# --- Catalog generation auth ---
# REQUIRED in production: POST /api/catalog/generate is refused when NODE_ENV
# is "production" and this is unset. In development it is optional (local
# requests are allowed). When set, callers must send `Authorization: Bearer <secret>`.
CATALOG_GENERATE_SECRET=

# --- Query parser policy (optional) ---
# Comma-separated preferred medium order steering ambiguous resolution.
QUERY_PREFERRED_MEDIA=Movie,History,Novel
# Clarification sensitivity, integer 1..40 (default 15).
QUERY_AMBIGUITY_MARGIN=15

# --- Ops check tuning (optional; consumed by scripts/ops-check.sh) ---
# OPERATIONS_BASE_URLS="https://sv.moss.land http://localhost:16100"
# OPERATIONS_RETRIES=2
# OPERATIONS_RETRY_DELAY_SECS=1
# OPERATIONS_REPORT_FILE=/tmp/storyverse-ops.json
# OPERATIONS_TUNNEL_PROCESS_NAME=storyverse-tunnel
